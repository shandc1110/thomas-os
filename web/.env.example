# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored so your secrets never get committed.

# Supabase project URL (safe to expose - shipped to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://yrpjtaqdwieavlhathvo.supabase.co

# Supabase publishable / anon key (safe to expose - shipped to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_tVIYXFaEoPU8ghYK-fePEg_RzDxrMIM

# Supabase service_role key (SECRET - server-side only, never expose to the browser).
# Required by /api/orders and the image upload script.
# Get it from Supabase -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
